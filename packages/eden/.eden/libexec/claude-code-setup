#!/usr/bin/env bash
# claude-code-setup - Install Claude Code using Anthropic's official installer
# https://docs.anthropic.com/en/docs/claude-code

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

print_success() { echo -e "${GREEN}✓${RESET} $1"; }
print_error() { echo -e "${RED}✗${RESET} $1" >&2; }
print_info() { echo -e "${BLUE}→${RESET} $1"; }
print_warning() { echo -e "${YELLOW}⚠${RESET} $1"; }
print_header() { echo -e "${BOLD}${BLUE}$1${RESET}"; }

if command -v claude &> /dev/null; then
    print_warning "Claude Code is already installed!"
    echo ""
    claude --version 2>/dev/null || true
    echo ""
    read -p "Do you want to reinstall/update? [y/N] " -n 1 -r
    echo
    if [[ ! $REPLY =~ ^[Yy]$ ]]; then
        print_info "Exiting without changes"
        exit 0
    fi
fi

print_header "Claude Code Setup"
echo ""
print_info "Installing via Anthropic's official installer"
echo ""

curl -fsSL https://claude.ai/install.sh | bash

echo ""
print_success "Claude Code installed"
echo ""

if command -v claude &> /dev/null; then
    claude --version 2>/dev/null || true
fi
