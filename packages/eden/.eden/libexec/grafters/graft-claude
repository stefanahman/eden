#!/bin/bash
# graft-claude - Symlink Claude Code configs from branches
#
# Grafts two scopes:
#   1. Global: .claude/{rules,agents,skills}/ → ~/.claude/
#   2. Project: projects/<path>/.claude/{rules,agents,skills}/ → <target>/.claude/
#      where <target> is read from projects/<path>/.eden-target
#      Any directory nesting is allowed (e.g. projects/games/greenwash/)
#
# Part of Eden's pluggable grafter system
set -e

# Report covered paths for eden doctor
if [[ "${1:-}" == "--covers" ]]; then
    echo ".claude"
    exit 0
fi

# Detect Eden root from script location
if [[ -z "$EDEN_ROOT" ]]; then
    SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
    EDEN_ROOT="$(cd "$(dirname "$SCRIPT_PATH")/../../../../.." && pwd)"
fi

# Expand variables in branch path
expand_path() {
    local path="$1"
    path="${path//\$EDEN_ROOT/$EDEN_ROOT}"
    path="${path/#\~/$HOME}"
    echo "$path"
}

BRANCHES_FILE="${XDG_CONFIG_HOME:-$HOME/.config}/eden/branches"

if [[ ! -f "$BRANCHES_FILE" ]]; then
    echo "  → No branches registered (skipping)"
    exit 0
fi

added=0
skipped=0
conflicts=()

# Track ownership for conflict detection
# Uses newline-separated "key=owner" strings (bash 3.2 compatible)
file_owners=""

_get_owner() {
    echo "$file_owners" | while IFS='=' read -r k v; do
        [ "$k" = "$1" ] && echo "$v" && return
    done
}

# Graft flat markdown files (rules/, agents/)
_graft_flat_dir() {
    local source_dir="$1" target_dir="$2" kind="$3" owner="$4"

    [[ -d "$source_dir" ]] || return 0
    mkdir -p "$target_dir"

    for file in "$source_dir"/*.md; do
        [[ -e "$file" ]] || continue

        local filename
        filename=$(basename "$file")
        local target="$target_dir/$filename"

        if [[ -L "$target" ]]; then
            local current_target
            current_target=$(readlink -f "$target" 2>/dev/null || readlink "$target")
            local expected
            expected=$(readlink -f "$file" 2>/dev/null || echo "$file")
            if [[ "$current_target" != "$expected" ]]; then
                local existing_owner
                existing_owner=$(_get_owner "$kind/$filename")
                conflicts+=("$kind/$filename: ${existing_owner:-unknown} vs $owner")
                continue
            fi
            echo "  ✓ $kind/$filename ($owner) [already linked]"
            skipped=$((skipped + 1))
            file_owners="${file_owners}${kind}/${filename}=${owner}"$'\n'
            continue
        elif [[ -e "$target" ]]; then
            conflicts+=("$kind/$filename: file exists (not a symlink)")
            continue
        fi

        ln -sf "$file" "$target"
        echo "  → $kind/$filename ($owner)"
        added=$((added + 1))
        file_owners="${file_owners}${kind}/${filename}=${owner}"$'\n'
    done
}

# Graft skill directories (each skill is a directory with SKILL.md)
_graft_skills_dir() {
    local source_dir="$1" target_dir="$2" owner="$3"

    [[ -d "$source_dir" ]] || return 0
    mkdir -p "$target_dir"

    for skill_dir in "$source_dir"/*/; do
        [[ -d "$skill_dir" ]] || continue

        local skill_name
        skill_name=$(basename "$skill_dir")
        local target="$target_dir/$skill_name"
        local key="skills/$skill_name"

        if [[ -L "$target" ]]; then
            local current_target
            current_target=$(readlink -f "$target" 2>/dev/null || readlink "$target")
            local expected
            expected=$(readlink -f "${skill_dir%/}" 2>/dev/null || echo "${skill_dir%/}")
            if [[ "$current_target" != "$expected" ]]; then
                local existing_owner
                existing_owner=$(_get_owner "$key")
                conflicts+=("$key: ${existing_owner:-unknown} vs $owner")
                continue
            fi
            echo "  ✓ $key ($owner) [already linked]"
            skipped=$((skipped + 1))
            file_owners="${file_owners}${key}=${owner}"$'\n'
            continue
        elif [[ -e "$target" ]]; then
            conflicts+=("$key: directory exists (not a symlink)")
            continue
        fi

        ln -sf "${skill_dir%/}" "$target"
        echo "  → $key ($owner)"
        added=$((added + 1))
        file_owners="${file_owners}${key}=${owner}"$'\n'
    done
}

# Graft all Claude configs from a source .claude/ dir into a target .claude/ dir
_graft_claude_dir() {
    local source_claude="${1%/}" target_claude="${2%/}" owner="$3"

    [[ -d "$source_claude" ]] || return 0

    for kind in rules agents; do
        _graft_flat_dir "$source_claude/$kind" "$target_claude/$kind" "$kind" "$owner"
    done
    _graft_skills_dir "$source_claude/skills" "$target_claude/skills" "$owner"
}

while IFS= read -r branch_path || [[ -n "$branch_path" ]]; do
    [[ -z "$branch_path" || "$branch_path" =~ ^[[:space:]]*# ]] && continue

    branch_path=$(expand_path "$branch_path")
    [[ -d "$branch_path" ]] || continue

    branch_name=$(basename "$branch_path")

    # 1. Global scope: branch/.claude/ → ~/.claude/
    _graft_claude_dir "$branch_path/.claude" "$HOME/.claude" "$branch_name"

    # 2. Project scope: discover all .eden-target files under projects/
    projects_dir="$branch_path/projects"
    if [[ -d "$projects_dir" ]]; then
        while IFS= read -r target_file || [[ -n "$target_file" ]]; do
            project_dir=$(dirname "$target_file")
            local_name="${project_dir#"$projects_dir"/}"

            project_target=$(expand_path "$(head -1 "$target_file" | tr -d '[:space:]')")

            if [[ ! -d "$project_target" ]]; then
                echo "  ⚠ projects/$local_name: target $project_target not found (skipping)"
                continue
            fi

            _graft_claude_dir "$project_dir/.claude" "$project_target/.claude" "$branch_name:$local_name"
        done < <(find "$projects_dir" -name .eden-target -type f || true)
    fi
done < "$BRANCHES_FILE"

# Report results
if [[ $added -gt 0 ]]; then
    echo "  → Grafted $added Claude config(s)"
fi
[[ $skipped -gt 0 ]] && echo "  → Skipped $skipped already grafted"

if [[ ${#conflicts[@]} -gt 0 ]]; then
    echo "  ⚠ Conflicts detected:"
    for conflict in "${conflicts[@]}"; do
        echo "    • $conflict"
    done
fi

if [[ $added -eq 0 && $skipped -eq 0 && ${#conflicts[@]} -eq 0 ]]; then
    echo "  → No Claude configs found in branches"
fi

exit 0
