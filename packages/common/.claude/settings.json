{
  "permissions": {
    "allow": [
      "Read(**/.env.example)",
      "Bash(gh api repos/bardo-technology/bardo-system/actions/runs:*)",
      "Bash(gh api repos/bardo-technology/bardo-system/actions/jobs:*)",
      "Bash(claude-afk)",
      "Bash(claude-back)"
    ],
    "deny": [
      "Read(**/.env)",
      "Read(**/.env.local)",
      "Read(**/.env.production)",
      "Read(**/.env.development)",
      "Read(/Users/stefan/Documents/Private/**)"
    ]
  },
  "enabledPlugins": {
    "rust-analyzer-lsp@claude-plugins-official": true
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "but claude pre-tool 2>/dev/null || true"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "but claude post-tool 2>/dev/null || true"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "but claude stop 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
