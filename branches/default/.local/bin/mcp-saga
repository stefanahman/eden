#!/bin/bash
# MCP wrapper: Saga news curation API
# Fetches API key from 1Password at runtime — never stored on disk.
set -euo pipefail

export PATH="$HOME/.eden/bin:$HOME/.volta/bin:$HOME/.local/bin:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
source op-mcp-warmup

SAGA_API_KEY=$(op_read 'op://Developer/saga-api-key/credential' my.1password.com)
export SAGA_API_KEY

exec npx -y mcp-remote https://saga.steflix.net/mcp \
    --header "X-API-Key: $SAGA_API_KEY"
